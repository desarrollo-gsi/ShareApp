<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:AvaloniaShareApp.Infrastructure.Ui.ViewModels"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="700"
             x:Class="AvaloniaShareApp.Infrastructure.Ui.Views.DashboardView"
             x:DataType="vm:DashboardViewModel">
    
    <UserControl.Styles>
        <Style Selector="Border.StatCard">
            <Setter Property="Background" Value="{DynamicResource MainBackground}"/>
            <Setter Property="CornerRadius" Value="24"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="BoxShadow" Value="{DynamicResource CardShadow}"/>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.StatCard:pointerover">
            <Setter Property="RenderTransform" Value="translateY(-5px)"/>
        </Style>

        <!-- Animation for entrance -->
        <Style Selector="StackPanel#MainStack > Grid">
            <Style.Animations>
                <Animation Duration="0:0:0.5" Easing="CubicEaseOut">
                    <KeyFrame KeyTime="0:0:0">
                        <Setter Property="Opacity" Value="0"/>
                        <Setter Property="TranslateTransform.Y" Value="20"/>
                    </KeyFrame>
                    <KeyFrame KeyTime="0:0:0.5">
                        <Setter Property="Opacity" Value="1"/>
                        <Setter Property="TranslateTransform.Y" Value="0"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        
        <Style Selector="Button.TemplateCard">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <ContentPresenter Background="Transparent" 
                                      BorderThickness="0"
                                      Content="{TemplateBinding Content}"/>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="Border.CardBody">
            <Setter Property="Background" Value="{DynamicResource MainBackground}"/>
            <Setter Property="CornerRadius" Value="24"/>
            <Setter Property="BoxShadow" Value="{DynamicResource CardShadow}"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.3" Easing="CubicEaseOut"/>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.3" Easing="CubicEaseOut"/>
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Button.TemplateCard:pointerover Border.CardBody">
            <Setter Property="BoxShadow" Value="0 10 30 0 #15000000"/>
            <Setter Property="RenderTransform" Value="scale(1.02)"/>
        </Style>
        <Style Selector="Button.ActionBtn">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.ActionBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#F1F5F9"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer>
        <StackPanel x:Name="MainStack" Spacing="30" Margin="24">
            <!-- Header section -->
            <Grid ColumnDefinitions="*, Auto, Auto">
                <StackPanel Spacing="8">
                    <TextBlock Text="{Binding UserName, StringFormat='¡Hola, {0}! 👋'}" 
                               FontSize="32" FontWeight="Bold" Foreground="{DynamicResource PrimaryText}"/>
                    <TextBlock Text="Bienvenido de nuevo a tu espacio de trabajo inteligente." 
                               FontSize="16" Foreground="{DynamicResource SecondaryText}"/>
                </StackPanel>

                <!-- Search Bar -->
                <Border Grid.Column="1" Background="{DynamicResource MainBackground}" 
                        CornerRadius="24" Padding="12,0" Margin="0,0,20,0" Width="320" Height="48"
                        VerticalAlignment="Center" BoxShadow="{DynamicResource CardShadow}">
                    <Grid ColumnDefinitions="Auto, *">
                        <TextBlock Text="🔍" VerticalAlignment="Center" Margin="12,0" Opacity="0.5"/>
                        <TextBox Grid.Column="1" Watermark="Buscar documentos..." 
                                 Text="{Binding SearchQuery}"
                                 VerticalAlignment="Center"
                                 BorderThickness="0" Background="Transparent" Padding="0,8"/>
                    </Grid>
                </Border>
                
                <!-- Storage Widget -->
                <Border Grid.Column="2" Background="{DynamicResource MainBackground}" 
                        CornerRadius="20" Padding="16" BoxShadow="{DynamicResource CardShadow}" Width="220">
                    <StackPanel Spacing="10">
                        <Grid ColumnDefinitions="*, Auto">
                            <TextBlock Text="Almacenamiento" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryText}"/>
                            <TextBlock Grid.Column="1" Text="{Binding TotalStorage}" FontSize="12" Foreground="{DynamicResource PrimaryText}"/>
                        </Grid>
                        <ProgressBar Height="8" CornerRadius="4" Value="{Binding StoragePercentage}" 
                                     Background="{DynamicResource SecondaryBackground}" Foreground="#3B82F6"/>
                        <TextBlock Text="45% utilizado de tu plan" FontSize="11" Foreground="{DynamicResource SecondaryText}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Stats Grid -->
            <UniformGrid Columns="3" Margin="0,10,0,0">
                <Border Classes="StatCard" Margin="0,0,12,0">
                    <Grid ColumnDefinitions="Auto, *">
                        <Border Width="48" Height="48" Background="#EEF2FF" CornerRadius="14">
                            <TextBlock Text="📄" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="16,0,0,0">
                            <TextBlock Text="Documentos" FontSize="13" Foreground="{DynamicResource SecondaryText}"/>
                            <TextBlock Text="128" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource PrimaryText}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Classes="StatCard" Margin="12,0">
                    <Grid ColumnDefinitions="Auto, *">
                        <Border Width="48" Height="48" Background="#ECFDF5" CornerRadius="14">
                            <TextBlock Text="🤝" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="16,0,0,0">
                            <TextBlock Text="Compartidos" FontSize="13" Foreground="{DynamicResource SecondaryText}"/>
                            <TextBlock Text="14" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource PrimaryText}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Classes="StatCard" Margin="12,0,0,0">
                    <Grid ColumnDefinitions="Auto, *">
                        <Border Width="48" Height="48" Background="#FFF1F2" CornerRadius="14">
                            <TextBlock Text="🗑️" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="16,0,0,0">
                            <TextBlock Text="Papelera" FontSize="13" Foreground="{DynamicResource SecondaryText}"/>
                            <TextBlock Text="3" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource PrimaryText}"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </UniformGrid>

            <!-- Recent Activity Section -->
            <StackPanel Spacing="16">
                <TextBlock Text="Actividad Reciente" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource PrimaryText}"/>
                
                <ItemsControl ItemsSource="{Binding RecentFiles}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="2" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Classes="TemplateCard"
                                    Command="{Binding $parent[UserControl].((vm:DashboardViewModel)DataContext).OpenFileCommand}"
                                    CommandParameter="{Binding Id}">
                                <Border Classes="CardBody" Margin="0,0,12,12" Padding="16">
                                    <Grid ColumnDefinitions="Auto, *, Auto">
                                        <Border Width="40" Height="40" Background="{Binding AccentColor}" CornerRadius="10" Opacity="0.1"/>
                                        <TextBlock Text="📄" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0"/>
                                        
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryText}" Margin="16,0" VerticalAlignment="Center"/>
                                        
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="12">
                                            <TextBlock Text="{Binding Modified}" FontSize="11" 
                                                       Foreground="{DynamicResource SecondaryText}" VerticalAlignment="Center"/>
                                            <Button Classes="ActionBtn"
                                                    Command="{Binding $parent[UserControl].((vm:DashboardViewModel)DataContext).DeleteFileCommand}"
                                                    CommandParameter="{Binding Id}">
                                                <TextBlock Text="🗑️" FontSize="12"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
